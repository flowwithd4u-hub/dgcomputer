{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dgcomputer",
  "compatibility_date": "2026-07-07",
  "observability": {
    "enabled": true
  },
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
